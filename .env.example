# LaborLink environment variables.
# Copy this file to .env.local and fill in the two values from your
# Supabase project (Dashboard → Settings → API). .env.local is gitignored.
#
# Anything prefixed VITE_ is PUBLIC and ends up in the client bundle.
# The URL and the anon key are designed to be public: every request they
# make is enforced by Row Level Security on the database.
#
# NEVER put the service_role key here or anywhere else in this repo.
# It bypasses RLS and belongs only in a server side secret store.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
